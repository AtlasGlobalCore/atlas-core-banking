generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 🏢 ORGANIZAÇÕES & ACESSOS (RBAC)
// ==========================================
model Organization {
  id          String            @id @default(uuid())
  name        String            @unique
  apiKey      String?           @unique
  users       User[]
  operators   OrgOperator[]
  tickets     OperationTicket[]
  createdAt   DateTime          @default(now())
}

enum OrgRole {
  ADMIN
  OPERATOR
  ACCOUNT_MANAGER
}

model OrgOperator {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String       @unique
  passwordHash   String
  role           OrgRole      @default(OPERATOR)
  ticketsCreated OperationTicket[]
}

// ==========================================
// 👤 UTILIZADORES (Sellers & Clientes Diretos)
// ==========================================
model User {
  id                     String            @id @default(uuid())
  organizationId         String?
  organization           Organization?     @relation(fields: [organizationId], references: [id])
  nickname               String?           @unique
  email                  String?           @unique
  phone                  String?           @unique
  telegramId             String?           @unique
  fullName               String?
  passwordHash           String?
  requiresPasswordChange Boolean           @default(true)
  tier                   TierLevel         @default(TIER_0_UNVERIFIED)
  status                 AccountStatus     @default(ACTIVE)
  wallets                Wallet[]
  transactions           Transaction[]
  tickets                OperationTicket[]
  stores                 Store[]
  paymentLinks           PaymentLink[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

enum TierLevel {
  TIER_0_UNVERIFIED
  TIER_1_BASIC
  TIER_2_VERIFIED
  TIER_3_CORPORATE
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum Currency {
  EUR
  BRL
  USDT
  USD
}

// ==========================================
// 💼 CARTEIRAS MULTI-MOEDA
// ==========================================
model Wallet {
  id                String        @id @default(uuid())
  walletReference   String        @unique
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  currency          Currency
  blockchainAddress String?       @unique
  turnkeyWalletId   String?       @unique
  balanceIncoming   Decimal       @default(0.00) @db.Decimal(20, 6)
  balancePending    Decimal       @default(0.00) @db.Decimal(20, 6)
  balanceAvailable  Decimal       @default(0.00) @db.Decimal(20, 6)
  balanceBlocked    Decimal       @default(0.00) @db.Decimal(20, 6)
  transactions      Transaction[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  @@unique([userId, currency])
}

model FeeSchedule {
  id               String          @id @default(uuid())
  tier             TierLevel
  transactionType  TransactionType
  currency         Currency?
  percentageFee    Decimal         @default(0.00) @db.Decimal(5, 4)
  fixedFee         Decimal         @default(0.00) @db.Decimal(20, 6)
  isManualOverride Boolean         @default(false)
  @@unique([tier, transactionType, currency])
}

// ==========================================
// 🧾 LEDGER & CONSOLIDAÇÃO
// ==========================================
enum TransactionType {
  PROXY_INCOMING
  SETTLEMENT
  PAYOUT
  SWAP
  TRANSFER
  FEE
}

enum TransactionStatus {
  INCOMING
  PENDING
  COMPLETED
  BLOCKED
  FAILED
}

model SettlementBatch {
  id           String        @id @default(uuid())
  batchNumber  String        @unique
  processedAt  DateTime      @default(now())
  totalAmount  Decimal       @db.Decimal(20, 6)
  currency     Currency
  transactions Transaction[]
}

model Transaction {
  id              String            @id @default(uuid())
  walletId        String
  wallet          Wallet            @relation(fields: [walletId], references: [id])
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  type            TransactionType
  status          TransactionStatus
  amount          Decimal           @db.Decimal(20, 6)
  feeApplied      Decimal           @default(0.00) @db.Decimal(20, 6)
  currency        Currency
  proxyReference  String?           @unique
  onrampReference String?           @unique
  description     String?
  batchId         String?
  batch           SettlementBatch?  @relation(fields: [batchId], references: [id])
  paymentLinkId   String?
  paymentLink     PaymentLink?      @relation(fields: [paymentLinkId], references: [id])
  customerId      String?
  customer        Customer?         @relation(fields: [customerId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([walletId])
  @@index([paymentLinkId])
  @@index([customerId])
}

model OperationTicket {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  creatorId       String
  creator         OrgOperator  @relation(fields: [creatorId], references: [id])
  targetUserId    String?
  targetUser      User?        @relation(fields: [targetUserId], references: [id])
  type            TicketType
  status          TicketStatus @default(OPEN)
  description     String
  resolutionNotes String?
  resolvedById    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum TicketType {
  MANUAL_WITHDRAWAL
  TIER_UPGRADE
  FEE_ADJUSTMENT
  SUPPORT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

// ==========================================
// 🛒 MÓDULO E-COMMERCE, CHECKOUT & CRM
// ==========================================
model Store {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  name           String
  slug           String        @unique
  branding       Json?
  allowedMethods Json?       // Ex: { "PIX": true, "STRIPE": true, "MBWAY": false }
  apiKey         String?       @unique  // NOVO: Chave para o Merchant usar a API S2S
  status         AccountStatus @default(ACTIVE)
  paymentLinks   PaymentLink[]
  customers      Customer[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PaymentLink {
  id             String        @id @default(uuid())
  storeId        String?
  store          Store?        @relation(fields: [storeId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  title          String
  description    String?
  amount         Decimal       @db.Decimal(20, 6)
  currency       Currency
  isActive       Boolean       @default(true)
  isReusable     Boolean       @default(false)
  
  // NOVOS: Campos de Redirecionamento S2S
  successUrl     String?
  cancelUrl      String?
  webhookUrl     String?
  
  transactions   Transaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Customer {
  id             String        @id @default(uuid())
  storeId        String
  store          Store         @relation(fields: [storeId], references: [id])
  name           String
  email          String
  document       String?
  phone          String?
  transactions   Transaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  @@unique([storeId, email])
}
